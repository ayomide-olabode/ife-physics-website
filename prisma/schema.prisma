generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum StaffType {
  ACADEMIC
  COGNATE
  VISITING
  EMERITUS
  TECHNICAL
  SUPPORT
}

enum StaffStatus {
  ACTIVE
  RESIGNED
  RETIRED
  IN_MEMORIAM
}

enum ProgramLevel {
  UNDERGRADUATE
  POSTGRADUATE
}

enum ProgrammeCode {
  PHY
  EPH
  SLT
}

enum DegreeType {
  BSC
  MSC
  MPHIL
  PHD
}

enum CourseStatus {
  CORE
  RESTRICTED
}

enum ScopedRole {
  // Global role (multiple users allowed)
  ACADEMIC_COORDINATOR

  // Scoped per ResearchGroup (per-group owners; enforce max 2 via app logic)
  RESEARCH_LEAD

  // Global role (single role covering Communications + Content; multiple users allowed)
  EDITOR
}

enum ScopeType {
  GLOBAL
  RESEARCH_GROUP
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum LeadershipRole {
  HOD
  ACADEMIC_COORDINATOR
}

enum ResearchOutputType {
  TECHNICAL_REPORT
  JOURNAL_ARTICLE
  BOOK
  MONOGRAPH
  CONFERENCE_PROCEEDINGS
  OTHER
}

enum ThesisStatus {
  ONGOING
  COMPLETED
  DISCONTINUED
}

enum EventOpportunityType {
  EVENT
  OPPORTUNITY
}

enum EventCategory {
  SEMINAR
  LECTURE
  COLLOQUIUM
  WORKSHOP
  TRAINING
  THESIS_DEFENSE
  CONFERENCE
  SYMPOSIUM
  SCHOOL
  MEETING
  SOCIAL
  OUTREACH
  COMPETITION
}

enum OpportunityCategory {
  GRANT
  FUNDING
  FELLOWSHIP
  SCHOLARSHIP
  JOBS
  INTERNSHIPS
  EXCHANGE
  COLLABORATION
}

//////////////////////////////////////////////////////
// STAFF & AUTHENTICATION
//////////////////////////////////////////////////////

model Staff {
  id                 String      @id @default(cuid())
  firstName          String?
  lastName           String?
  institutionalEmail String      @unique

  staffType          StaffType
  staffStatus        StaffStatus @default(ACTIVE)

  // Visiting faculty
  visitStartDate     DateTime?
  visitEndDate       DateTime?

  // Academic/faculty fields
  academicRank       String?
  designation        String?
  researchArea       String?
  roomNumber         String?
  academicLinkUrl    String?

  // Technical/Support fields
  operationalUnit    String?
  areaOfExpertise    String?

  phoneNumber        String?
  bio                String?
  researchInterests  String?
  profileImageUrl    String?

  user               User?

  // Relations
  researchMemberships  ResearchGroupMembership[]
  publicationAuthorship PublicationAuthor[]

  researchOutputs     ResearchOutput[]
  projects            Project[]
  teaching            TeachingResponsibility[]
  thesesSupervised    StudentThesis[]

  leadershipTerms     LeadershipTerm[]
  hodAddress          HodAddress?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?

  @@index([staffStatus])
  @@index([staffType])
}

model User {
  id            String   @id @default(cuid())
  staffId       String   @unique
  staff         Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  passwordHash  String
  isSuperAdmin  Boolean  @default(false)

  roleAssignments RoleAssignment[]
  auditLogs       AuditLog[] @relation("ActorAuditLogs")

  lastLoginAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

//////////////////////////////////////////////////////
// RBAC SYSTEM
//////////////////////////////////////////////////////

model RoleAssignment {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  role      ScopedRole
  scopeType ScopeType
  scopeId   String?   // REQUIRED when scopeType=RESEARCH_GROUP (enforced in app logic)

  expiresAt DateTime?
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([role, scopeType, scopeId])

  // Prevent duplicates (same user assigned same role to same scope twice)
  @@unique([userId, role, scopeType, scopeId])
}

//////////////////////////////////////////////////////
// RESEARCH DOMAIN
//////////////////////////////////////////////////////

model ResearchGroup {
  id           String   @id @default(cuid())
  name         String
  abbreviation String
  slug         String   @unique
  imageUrl     String?
  overview     String?
  focusAreas   String?

  memberships  ResearchGroupMembership[]
  publications Publication[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?
}

model ResearchGroupMembership {
  id              String        @id @default(cuid())
  staffId         String
  researchGroupId String

  staff           Staff         @relation(fields: [staffId], references: [id], onDelete: Cascade)
  researchGroup   ResearchGroup @relation(fields: [researchGroupId], references: [id], onDelete: Cascade)

  joinedAt        DateTime?
  leftAt          DateTime?

  @@unique([staffId, researchGroupId])
}

model Publication {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  doi             String?  @unique
  year            Int
  type            String?
  abstract        String?
  url             String?

  // Homepage rule: pick 1 featured publication per ResearchGroup
  isFeatured      Boolean  @default(false)

  researchGroupId String?
  researchGroup   ResearchGroup? @relation(fields: [researchGroupId], references: [id])

  authors         PublicationAuthor[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deletedAt       DateTime?

  @@index([year])
  @@index([researchGroupId, isFeatured])
}

model PublicationAuthor {
  id            String   @id @default(cuid())
  publicationId String
  staffId       String?
  externalName  String?
  authorOrder   Int

  publication   Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)
  staff         Staff?      @relation(fields: [staffId], references: [id])

  @@unique([publicationId, authorOrder])
}

//////////////////////////////////////////////////////
// PEOPLE: OUTPUTS / PROJECTS / TEACHING / THESES
//////////////////////////////////////////////////////

model ResearchOutput {
  id        String           @id @default(cuid())
  staffId   String
  staff     Staff            @relation(fields: [staffId], references: [id], onDelete: Cascade)

  type      ResearchOutputType
  title     String
  year      Int?
  venue     String?
  url       String?
  doi       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model Project {
  id          String   @id @default(cuid())
  staffId     String
  staff       Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  title       String
  description String?
  url         String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}

model TeachingResponsibility {
  id          String   @id @default(cuid())
  staffId     String
  staff       Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  courseCode  String?
  title       String
  sessionYear Int?     // e.g., 2025
  semester    String?  // e.g., "Harmattan"

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}

model StudentThesis {
  id        String       @id @default(cuid())
  staffId   String
  staff     Staff        @relation(fields: [staffId], references: [id], onDelete: Cascade)

  year      Int
  title     String
  studentName String?
  programme   String?
  degreeLevel String?
  status    ThesisStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

//////////////////////////////////////////////////////
// LEADERSHIP (HOD / COORDINATORS)
//////////////////////////////////////////////////////

model LeadershipTerm {
  id            String         @id @default(cuid())
  staffId        String
  staff          Staff          @relation(fields: [staffId], references: [id], onDelete: Cascade)

  role           LeadershipRole
  startDate      DateTime
  endDate        DateTime?

  // Optional: if you want to tag academic coordinators by programme for display,
  // without making them "owners" in RBAC:
  programmeCode  ProgrammeCode?

  createdAt      DateTime @default(now())

  @@index([role, endDate])
  @@index([programmeCode])
}

model HodAddress {
  id        String   @id @default(cuid())
  staffId   String   @unique
  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  title     String
  body      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

//////////////////////////////////////////////////////
// ACADEMIC DOMAIN (PHY/EPH/SLT UG/PG)
//////////////////////////////////////////////////////

model AcademicProgram {
  id            String        @id @default(cuid())
  programmeCode ProgrammeCode
  level         ProgramLevel

  slug          String        @unique

  // Sections (UG/PG)
  overviewProspects     String?
  admissionRequirements String?
  courseRequirements    String?
  curriculum            String?
  programmeStructure    String?

  // PG accordion blocks for admission/course requirements
  requirementBlocks RequirementBlock[]

  studyOptions   StudyOption[]
  courses        Course[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  @@unique([programmeCode, level])
}

model RequirementBlock {
  id         String     @id @default(cuid())
  programId  String
  program    AcademicProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  // "admissionRequirements" | "courseRequirements"
  section    String
  degreeType DegreeType
  content    String

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([programId, section, degreeType])
}

model StudyOption {
  id        String   @id @default(cuid())
  programId String
  program   AcademicProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  name      String
  about     String

  courses   CourseOnStudyOption[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model Course {
  id            String       @id @default(cuid())
  code          String       @unique
  title         String
  description   String?
  prerequisites String?

  // L/T/P/U fields (numbers)
  L             Int?
  T             Int?
  P             Int?
  U             Int?

  status        CourseStatus @default(CORE)

  programId     String
  program       AcademicProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  studyOptions  CourseOnStudyOption[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  @@index([programId])
}

model CourseOnStudyOption {
  courseId      String
  studyOptionId String

  course        Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  studyOption   StudyOption @relation(fields: [studyOptionId], references: [id], onDelete: Cascade)

  @@id([courseId, studyOptionId])
}

//////////////////////////////////////////////////////
// COMMUNICATIONS + CONTENT (Editor-managed)
//////////////////////////////////////////////////////

model News {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  body        String
  imageUrl    String?
  date        DateTime

  // Homepage hero carousel: 4 featured news
  isFeatured  Boolean       @default(false)

  buttonLabel String?
  buttonLink  String?

  status      PublishStatus @default(DRAFT)
  publishedAt DateTime?
  archivedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([isFeatured, date])
  @@index([status])
}

model EventOpportunity {
  id                   String               @id @default(cuid())
  title                String
  type                 EventOpportunityType
  eventCategory        EventCategory?
  opportunityCategory  OpportunityCategory?
  description          String?
  startDate            DateTime?
  endDate              DateTime?
  venue                String?
  linkUrl              String?
  deadline             DateTime?

  status               PublishStatus        @default(DRAFT)
  publishedAt          DateTime?
  archivedAt           DateTime?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  deletedAt            DateTime?

  @@index([type, deadline])
  @@index([status])
}

model Spotlight {
  id          String        @id @default(cuid())
  title       String
  date        DateTime?
  imageUrl    String?
  text        String

  status      PublishStatus @default(DRAFT)
  publishedAt DateTime?
  archivedAt  DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?

  @@index([status])
}

model HistoryEntry {
  id        String   @id @default(cuid())
  date      DateTime
  title     String
  shortDesc String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([date])
}

model RollOfHonourEntry {
  id                String   @id @default(cuid())
  imageUrl           String?
  name               String
  registrationNumber String?
  programme          String   // display string ("PHY", etc.)
  cgpa               Float?
  graduatingYear     Int

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?
}

model LegacyGalleryItem {
  id        String   @id @default(cuid())
  mediaUrl  String
  title     String
  bioText   String
  datesText String?  // e.g., "1978–2004"
  year      Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

//////////////////////////////////////////////////////
// RESOURCES
//////////////////////////////////////////////////////

model ResourceItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  link        String
  imageUrl    String?
  category    String?  // e.g., "Apps", "Documents", "Forms"

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}

//////////////////////////////////////////////////////
// AUDIT SYSTEM
//////////////////////////////////////////////////////

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  actor      User?    @relation("ActorAuditLogs", fields: [actorId], references: [id])

  action     String
  entityType String
  entityId   String
  snapshot   Json

  createdAt  DateTime @default(now())
}